// Headers
{#}[1..6]{ }[..]{!\n} => "<h{{#0}}>{{$2}}</h{{#0}}>"

{**}{!**}{**} => "<b>{{$1}}</b>"         // Bold
{`}{!`}[1..]{`} => "<code>{{$1}}</code>" // Code

// Line breaks
{\n---\n} => "\n<hr/>\n"
{\n***\n} => "\n<hr/>\n"
{\n___\n} => "\n<hr/>\n"

// Tables
{{{|..}{!|,\n}[..]{|..}}[2..#]\n}[3..]
  => "<table>\n{{0$}}</table>"
  => {\n}[1..]{|..}{!\n,</table>}
  => "<tr>|{{$2}}</tr>"
  => {|}[1..]{!|,</tr>}
  => "<td>{{$1}}</td>"