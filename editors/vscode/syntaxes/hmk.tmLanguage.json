{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Himark",
  "scopeName": "source.hmk",
  "patterns": [
    { "include": "#comment" },
    { "include": "#template" },
    { "include": "#arrow" },
    { "include": "#count" },
    { "include": "#group" },
    { "include": "#escape" }
  ],
  "repository": {
    "comment": {
      "match": "//.*$",
      "name": "comment.line.double-slash.hmk"
    },
    "arrow": {
      "match": "=>|<=",
      "name": "keyword.operator.arrow.hmk"
    },
    "escape": {
      "match": "\\\\.",
      "name": "constant.character.escape.hmk"
    },
    "count": {
      "name": "meta.count.hmk",
      "begin": "\\[",
      "end": "\\]",
      "beginCaptures": { "0": { "name": "punctuation.definition.count.begin.hmk" } },
      "endCaptures": { "0": { "name": "punctuation.definition.count.end.hmk" } },
      "patterns": [
        { "match": "#\\d+", "name": "variable.language.reference.count.hmk" },
        { "match": "\\d+", "name": "constant.numeric.count.hmk" },
        { "match": "\\.\\.|,", "name": "keyword.operator.count.hmk" }
      ]
    },
    "group": {
      "name": "meta.group.hmk",
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.definition.group.begin.hmk" } },
      "endCaptures": { "0": { "name": "punctuation.definition.group.end.hmk" } },
      "patterns": [
        { "include": "#escape" },
        { "match": "@(?:\\^\\^|\\$\\$|\\^|\\$)", "name": "keyword.control.anchor.hmk" },
        { "match": "@[A-Za-z][A-Za-z0-9]*", "name": "support.constant.macro.hmk" },
        { "match": "\\$\\d+|#\\d+|\\d+\\$[0-9.]*", "name": "variable.language.reference.hmk" },
        { "match": "\\.\\.|[,:!]", "name": "keyword.operator.group.hmk" },
        { "include": "#count" },
        { "include": "#group" }
      ]
    },
    "template": {
      "name": "string.quoted.double.hmk",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.hmk" } },
      "endCaptures": { "0": { "name": "punctuation.definition.string.end.hmk" } },
      "patterns": [
        { "include": "#escape" },
        { "include": "#moustache" }
      ]
    },
    "moustache": {
      "name": "meta.template-expression.hmk",
      "begin": "\\{\\{",
      "end": "\\}\\}",
      "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.hmk" } },
      "endCaptures": { "0": { "name": "punctuation.definition.template-expression.end.hmk" } },
      "patterns": [
        { "match": ">", "name": "keyword.operator.payload.hmk" },
        { "match": "\\|", "name": "keyword.operator.pipe.hmk" },
        {
          "match": "\\b(?:upper|lower|trim|indent|len|hex|sha256|head|tail|b256)\\b",
          "name": "support.function.filter.hmk"
        },
        { "match": "\\d+", "name": "constant.numeric.hmk" },
        { "match": "\\d*[$#][0-9.]*|\\.", "name": "variable.other.accessor.hmk" }
      ]
    }
  }
}
