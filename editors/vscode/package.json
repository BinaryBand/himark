{
  "name": "himark-hmk",
  "displayName": "Himark (HMK)",
  "description": "Syntax highlighting for Himark (.hmk) pattern and transform scripts.",
  "version": "0.1.0",
  "publisher": "himark",
  "license": "CC0-1.0",
  "engines": { "vscode": "^1.60.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "hmk",
        "aliases": ["Himark", "hmk"],
        "extensions": [".hmk"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hmk",
        "scopeName": "source.hmk",
        "path": "./syntaxes/hmk.tmLanguage.json"
      }
    ]
  }
}
